# OmniVoice — ngrok public URL of your local FastAPI service
# Run: ngrok http 8000  →  copy the https://xxx.ngrok-free.app URL here
# Leave empty to skip OmniVoice and fall back to ElevenLabs
OMNIVOICE_URL=

# Neon PostgreSQL connection string
DATABASE_URL=

# OpenRouter — get from openrouter.ai (free models available, no credit card needed)
OPENROUTER_API_KEY=
VITE_OPENROUTER_API_KEY=

# ElevenLabs — get from elevenlabs.io (optional, has browser fallback)
ELEVENLABS_API_KEY=
# Client-side ElevenLabs key — used as fallback on Vercel where there's no Express backend
# Same key as above, but prefixed with VITE_ so Vite exposes it to the browser
VITE_ELEVENLABS_API_KEY=

# Cloudinary — get from cloudinary.com (free tier: 25GB storage)
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=

# Firebase — from firebase-applet-config.json (public client config, safe to commit)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Backend URL — set this on Vercel to point at your deployed Express server (e.g. Railway/Render)
# Leave empty for local dev (Express serves both frontend and API on the same port)
VITE_API_BASE=
